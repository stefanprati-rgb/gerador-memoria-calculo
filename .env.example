# ---------------------------------------------------------
# Configurações Obrigatórias para Produção Cloud (Firebase)
# ---------------------------------------------------------
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
FIREBASE_STORAGE_BUCKET=hube-energy.appspot.com

# ---------------------------------------------------------
# Segurança (Obrigatório em Produção)
# ---------------------------------------------------------
# Altere esta senha. O uso do valor "mudar_aqui" bloqueia o app em modo de produção.
ADMIN_PASSWORD=uma_senha_muito_forte

# ---------------------------------------------------------
# Caminho de Rede (Opcional - Apenas para uso Local/Offline)
# ---------------------------------------------------------
# Defina este caminho se quiser permitir o sync automático da base via rede local (OneDrive/Mapeamento)
# Exemplo Windows: C:/Users/Usuario/GRUPO GERA/Gestão GDC - Documentos/RAÍZEN/05 - Gestao/Balanco_Energetico_Raizen.xlsm
NETWORK_SHARE_PATH=

# ---------------------------------------------------------
# Outras Configurações (Opcional)
# ---------------------------------------------------------
LOG_LEVEL=INFO
BASE_SHEET_NAME=Balanco Operacional
TEMPLATE_FILE=mc.xlsx
